{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "Node16",
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"outDir": "./lib",
		"downlevelIteration": true,
		"esModuleInterop": true,
		"strict": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"useUnknownInCatchVariables": false,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"src/**/*_test.ts"
	]
}