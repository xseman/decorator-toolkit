			"import": "./lib/memoize/index.js",
			"require": "./lib/memoize/index.js"
		},
		"./memoize-async": {
			"types": "./lib/memoize-async/index.d.ts",
			"bun": "./src/memoize-async/index.ts",
			"import": "./lib/memoize-async/index.js",
			"require": "./lib/memoize-async/index.js"
		},
		"./multi-dispatch": {
			"types": "./lib/multi-dispatch/index.d.ts",
