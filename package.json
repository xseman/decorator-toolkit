{
	"name": "decorator-toolkit",
	"description": "Modern TC39 decorators for reducing repetitive code.",
	"type": "module",
	"version": "0.1.2",
	"license": "Apache-2.0",
	"funding": "https://github.com/sponsors/xseman",
	"homepage": "https://github.com/xseman/decorator-toolkit",
	"keywords": [
		"typescript",
		"decorator",
		"tc39"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/xseman/decorator-toolkit"
	},
	"scripts": {
		"build": "tsc --build",
		"fmt": "dprint fmt",
		"fmt:check": "dprint check",
		"typecheck": "tsc --noEmit",
		"test": "bun test src/ --coverage --coverage-reporter=text --coverage-reporter=lcov --concurrent",
		"test:watch": "bun test src/ --watch --coverage --concurrent"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^24.11.1",
		"dprint": "~0.52.0",
		"typescript": "~5.9.3"
	},
	"engines": {
		"bun": ">=13.1.10",
		"node": ">=18.0.0"
	},
	"sideEffects": false,
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./lib/index.d.ts",
			"bun": "./src/index.ts",
			"import": "./lib/index.js",
			"require": "./lib/index.js"
		},
		"./after": {
			"types": "./lib/after/index.d.ts",
			"bun": "./src/after/index.ts",
			"import": "./lib/after/index.js",
			"require": "./lib/after/index.js"
		},
		"./before": {
			"types": "./lib/before/index.d.ts",
			"bun": "./src/before/index.ts",
			"import": "./lib/before/index.js",
			"require": "./lib/before/index.js"
		},
		"./bind": {
			"types": "./lib/bind/index.d.ts",
			"bun": "./src/bind/index.ts",
			"import": "./lib/bind/index.js",
			"require": "./lib/bind/index.js"
		},
		"./bind-all": {
			"types": "./lib/bind-all/index.d.ts",
			"bun": "./src/bind-all/index.ts",
			"import": "./lib/bind-all/index.js",
			"require": "./lib/bind-all/index.js"
		},
		"./cancel-previous": {
			"types": "./lib/cancel-previous/index.d.ts",
			"bun": "./src/cancel-previous/index.ts",
			"import": "./lib/cancel-previous/index.js",
			"require": "./lib/cancel-previous/index.js"
		},
		"./debounce": {
			"types": "./lib/debounce/index.d.ts",
			"bun": "./src/debounce/index.ts",
			"import": "./lib/debounce/index.js",
			"require": "./lib/debounce/index.js"
		},
		"./delegate": {
			"types": "./lib/delegate/index.d.ts",
			"bun": "./src/delegate/index.ts",
			"import": "./lib/delegate/index.js",
			"require": "./lib/delegate/index.js"
		},
		"./delay": {
			"types": "./lib/delay/index.d.ts",
			"bun": "./src/delay/index.ts",
			"import": "./lib/delay/index.js",
			"require": "./lib/delay/index.js"
		},
		"./exec-time": {
			"types": "./lib/exec-time/index.d.ts",
