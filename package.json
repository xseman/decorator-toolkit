			"import": "./lib/readonly/index.js",
			"require": "./lib/readonly/index.js"
		},
		"./refreshable": {
			"types": "./lib/refreshable/index.d.ts",
			"bun": "./src/refreshable/index.ts",
			"import": "./lib/refreshable/index.js",
			"require": "./lib/refreshable/index.js"
		},
		"./retry": {
			"types": "./lib/retry/index.d.ts",
			"bun": "./src/retry/index.ts",
			"import": "./lib/retry/index.js",
			"require": "./lib/retry/index.js"
		},
		"./throttle": {
			"types": "./lib/throttle/index.d.ts",
			"bun": "./src/throttle/index.ts",
			"import": "./lib/throttle/index.js",
			"require": "./lib/throttle/index.js"
		},
		"./throttle-async": {
			"types": "./lib/throttle-async/index.d.ts",
			"bun": "./src/throttle-async/index.ts",
			"import": "./lib/throttle-async/index.js",
			"require": "./lib/throttle-async/index.js"
		},
		"./timeout": {
			"types": "./lib/timeout/index.d.ts",
			"bun": "./src/timeout/index.ts",
			"import": "./lib/timeout/index.js",
			"require": "./lib/timeout/index.js"
		}
	},
	"files": [
		"lib/**/*.js",
		"lib/**/*.d.ts",
		"!lib/**/*_test*",
		"src/**/*.ts",
		"!src/**/*_test.ts"
	]
}
